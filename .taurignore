**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/.Python

# Virtual environments
**/venv
**/env
**/.venv

# IDE
**/.vscode
**/.idea
**/*.swp
**/*.swo

# Git
**/.git
**/.gitignore

# Node modules (if any in python-backend)
**/node_modules

# Logs
**/*.log

# OS files
**/.DS_Store
**/Thumbs.db

# Large files that shouldn't be bundled
**/image/image_backup
