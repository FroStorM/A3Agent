{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "A3Agent",
  "version": "0.1.0",
  "identifier": "com.guofang.a3agent",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "A3Agent",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/python-backend"
    ],
    "resources": [
      "../ga_config/**/*",
      "../python-backend/**/*",
      "../frontend/**/*"
    ]
  }
}
