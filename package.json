{
  "name": "a3-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "tauri": "node ./node_modules/@tauri-apps/cli/tauri.js",
    "build:frontend": "node ./node_modules/tailwindcss/lib/cli.js -c frontend/tailwind.config.cjs -i frontend/tailwind-input.css -o frontend/vendor/tailwind.css --minify",
