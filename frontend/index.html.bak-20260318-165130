<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Generic Agent</title>
    <script>
        (function () {
            try {
                const mode = localStorage.getItem('ga_theme') || 'light';
                const isDark = mode === 'dark' || (mode === 'system' && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches);
                if (isDark) document.documentElement.classList.add('dark');
                else document.documentElement.classList.remove('dark');
                document.documentElement.style.colorScheme = isDark ? 'dark' : 'light';
            } catch (e) {
            }
        })();
    </script>
    <script>
        window.tailwind = window.tailwind || {};
        window.tailwind.config = { darkMode: 'class' };
    </script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        [v-cloak] { display: none; }
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
        *, *::before, *::after { box-sizing: border-box; }

        .ga-modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 50;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 16px;
        }
        .ga-modal-backdrop {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
        }
        .ga-modal-panel {
            position: relative;
            width: 100%;
            max-width: 1024px;
            max-height: 85vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            border-radius: 12px;
        }
        .ga-modal-body {
            flex: 1;
            overflow: auto;
        }
        .ga-todo-textarea {
            width: 100%;
            height: 55vh;
            resize: none;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            font-size: 14px;
            line-height: 1.4;
        }

        select option {
            background-color: #ffffff;
            color: #111827;
        }
        html.dark select option {
            background-color: #111827;
            color: #f3f4f6;
        }
        html.dark select,
        html.dark input,
        html.dark textarea,
        html.dark button {
            color-scheme: dark;
        }
        html:not(.dark) select,
        html:not(.dark) input,
        html:not(.dark) textarea,
        html:not(.dark) button {
            color-scheme: light;
        }
        
        /* Custom Markdown Styles */
        .prose pre {
            background-color: #f3f4f6;
            border-radius: 0.5rem;
            padding: 1rem;
            overflow-x: auto;
        }
        .dark .prose pre {
            background-color: #1f2937;
        }
        .prose code {
            color: #ef4444;
            background-color: #f3f4f6;
            padding: 0.125rem 0.25rem;
            border-radius: 0.25rem;
            font-size: 0.875em;
        }
        .dark .prose code {
            color: #f87171;
            background-color: #374151;
        }
        .prose pre code {
            color: inherit;
            background-color: transparent;
            padding: 0;
        }
        .animate-fade-in-up {
            animation: fadeInUp 0.3s ease-out;
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        html.dark .dark\:bg-gray-900 { background-color: #111827 !important; }
        html.dark .dark\:bg-gray-800 { background-color: #1f2937 !important; }
        html.dark .dark\:bg-gray-700 { background-color: #374151 !important; }
        html.dark .dark\:bg-gray-900\/20 { background-color: rgba(17, 24, 39, 0.2) !important; }
        html.dark .dark\:bg-blue-900\/20 { background-color: rgba(30, 58, 138, 0.2) !important; }
        html.dark .dark\:bg-blue-900\/30 { background-color: rgba(30, 58, 138, 0.3) !important; }
        html.dark .dark\:bg-yellow-900 { background-color: #78350f !important; }
        html.dark .dark\:bg-purple-900\/20 { background-color: rgba(88, 28, 135, 0.2) !important; }
        html.dark .dark\:bg-red-900\/20 { background-color: rgba(127, 29, 29, 0.2) !important; }

        html.dark .dark\:border-gray-700 { border-color: #374151 !important; }
        html.dark .dark\:border-blue-800 { border-color: #1e40af !important; }

        html.dark .dark\:text-gray-100 { color: #f3f4f6 !important; }
        html.dark .dark\:text-gray-200 { color: #e5e7eb !important; }
        html.dark .dark\:text-gray-300 { color: #d1d5db !important; }
        html.dark .dark\:text-gray-400 { color: #9ca3af !important; }
        html.dark .dark\:text-gray-500 { color: #6b7280 !important; }
        html.dark .dark\:text-blue-400 { color: #60a5fa !important; }
        html.dark .dark\:text-blue-300 { color: #93c5fd !important; }
        html.dark .dark\:text-purple-400 { color: #c084fc !important; }
        html.dark .dark\:text-red-400 { color: #f87171 !important; }
        html.dark .dark\:text-yellow-200 { color: #fef08a !important; }

        html.dark .dark\:hover\:bg-gray-700:hover { background-color: #374151 !important; }
        html.dark .dark\:hover\:bg-gray-600:hover { background-color: #4b5563 !important; }
        html.dark .dark\:hover\:bg-purple-900\/20:hover { background-color: rgba(88, 28, 135, 0.2) !important; }
        html.dark .dark\:hover\:bg-red-900\/20:hover { background-color: rgba(127, 29, 29, 0.2) !important; }

        html.dark aside button {
            background-color: transparent;
        }
        html.dark aside button.w-full {
            background-color: rgba(255, 255, 255, 0.06);
        }
        html.dark #themeToggle {
            background-color: rgba(255, 255, 255, 0.06);
        }
    </style>
</head>
<body class="bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100 font-sans antialiased h-screen overflow-hidden">
    <div id="app" v-cloak class="flex h-full">
        <!-- Sidebar -->
        <aside class="w-64 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 flex flex-col transition-all duration-300 z-20 absolute md:relative h-full shadow-lg md:shadow-none overflow-hidden" 
               :class="{'w-0 opacity-0 border-none': !sidebarOpen, 'w-64 opacity-100': sidebarOpen}">
            <div class="p-4 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between h-14">
                <div class="flex items-center gap-2 min-w-0">
                    <img src="logo_square.png" class="w-8 h-8 rounded-md" alt="Logo">
                    <h1 class="min-w-0 text-xl font-bold bg-gradient-to-r from-blue-500 to-purple-600 bg-clip-text text-transparent truncate">Generic Agent</h1>
                </div>
                <button id="themeToggle" type="button" class="shrink-0 p-1.5 rounded-md border border-gray-200 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-600 dark:text-gray-200" title="主题：浅色（点击切换）"></button>
                <button @click="sidebarOpen = false" class="md:hidden text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            
            <div class="flex-1 overflow-y-auto p-4 space-y-4">
                <!-- Status Card -->
                <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg p-3 border border-blue-100 dark:border-blue-800 space-y-2">
                    <div>
                        <div class="text-xs text-blue-600 dark:text-blue-400 font-semibold mb-1">当前模型</div>
                        <div class="text-sm font-medium truncate" :title="status.llm_name">{{ status.llm_name || '加载中...' }}</div>
                        <div class="mt-2 flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full transition-colors duration-300" :class="status.is_running ? 'bg-green-500 animate-pulse' : 'bg-gray-400'"></span>
                            <span class="text-xs text-gray-500 dark:text-gray-400">{{ status.is_running ? '运行中' : '空闲' }}</span>
                        </div>
                    </div>
                    
                    <div class="pt-2 border-t border-blue-200 dark:border-blue-800 space-y-2">
                         <div class="flex items-center justify-between">
                            <span class="text-xs text-gray-500 dark:text-gray-400">自主行动</span>
                            <button @click="toggleAutonomous" 
                                class="relative inline-flex h-5 w-9 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
                                :class="status.autonomous_enabled ? 'bg-green-500' : 'bg-gray-300'">
                                <span class="inline-block h-3 w-3 transform rounded-full bg-white transition duration-200 ease-in-out"
                                    :class="status.autonomous_enabled ? 'translate-x-5' : 'translate-x-1'"></span>
                            </button>
                        </div>
                        <div v-if="status.autonomous_enabled" class="space-y-1">
                             <div class="flex items-center justify-between text-xs text-gray-400">
                                <span>触发阈值:</span>
                                <select @change="updateThreshold" v-model="status.autonomous_threshold" class="bg-transparent border border-gray-300 dark:border-gray-700 rounded px-1 py-0.5 text-xs focus:outline-none">
                                    <option :value="60">1分钟</option>
                                    <option :value="300">5分钟</option>
                                    <option :value="1800">30分钟</option>
                                    <option :value="3600">1小时</option>
                                </select>
                             </div>
                            <div class="text-xs text-gray-400">
                               空闲: {{ formatTime(status.idle_time) }}
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="space-y-2">
                    <div class="space-y-1">
                        <div class="text-xs font-semibold text-gray-500 dark:text-gray-400 px-2 uppercase tracking-wider mb-2">配置</div>
                        <button @click="openModal('model')" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-md transition-colors">
                            <i data-lucide="cpu" class="w-4 h-4"></i>
                            模型切换
                        </button>
                        <button @click="openModal('sop')" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-md transition-colors">
                            <i data-lucide="book-open" class="w-4 h-4"></i>
                            SOP 技能库
                        </button>
                        <button @click="openModal('todo')" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-md transition-colors">
                            <i data-lucide="check-square" class="w-4 h-4"></i>
                            ToDo 计划
                        </button>
                        <button @click="openModal('schedule')" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-md transition-colors">
                            <i data-lucide="clock" class="w-4 h-4"></i>
                            定时触发工具
                        </button>
                        <button @click="reloadAgent" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-md transition-colors">
                            <i data-lucide="refresh-cw" class="w-4 h-4"></i>
                            重载配置/模型
                        </button>
                    </div>
                    
                    <div class="h-px bg-gray-200 dark:bg-gray-700 my-2"></div>

                    <button @click="triggerAutonomous" v-if="status.autonomous_enabled" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-purple-600 dark:text-purple-400 hover:bg-purple-50 dark:hover:bg-purple-900/20 rounded-md transition-colors">
                        <i data-lucide="zap" class="w-4 h-4"></i>
                        立即触发自主行动
                    </button>
                     <button @click="injectSysPrompt" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-md transition-colors">
                        <i data-lucide="refresh-cw" class="w-4 h-4"></i>
                        重新注入Prompt
                    </button>
                    <button @click="stopTask" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-md transition-colors">
                        <i data-lucide="square" class="w-4 h-4"></i>
                        停止任务
                    </button>
                    <button @click="clearHistory" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-md transition-colors">
                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                        清空历史
                    </button>
                </div>
            </div>

            <div class="p-4 border-t border-gray-200 dark:border-gray-700 text-xs text-center text-gray-400">
                Copyright © 2026 KW@FUDAN  All Rights Reserved 
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col h-full relative w-full bg-white dark:bg-gray-900">
            <!-- Sidebar Expand Button -->
            <button v-if="!sidebarOpen" @click="sidebarOpen = true" class="absolute left-0 top-1/2 -translate-y-1/2 z-30 p-1.5 bg-white dark:bg-gray-800 border border-l-0 border-gray-200 dark:border-gray-700 rounded-r-lg shadow-md hover:bg-gray-50 dark:hover:bg-gray-700 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition-all hover:pl-2 hidden md:block">
                <i data-lucide="chevron-right" class="w-5 h-5"></i>
            </button>

            <!-- Header -->
            <header class="h-14 bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 flex items-center px-4 justify-between shadow-sm z-10 shrink-0">
                <button @click="sidebarOpen = !sidebarOpen" class="p-2 rounded-md hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-600 dark:text-gray-300 transition-colors">
                    <i data-lucide="menu" class="w-5 h-5"></i>
                </button>
                <div class="font-medium text-gray-700 dark:text-gray-200">对话</div>
                <div class="w-8"></div> <!-- Spacer for balance -->
            </header>

            <!-- Chat Area -->
            <div id="chat-container" class="flex-1 overflow-y-auto p-4 space-y-6 scroll-smooth pb-24">
                <div v-if="messages.length === 0" class="flex flex-col items-center justify-center h-full text-gray-400 dark:text-gray-500 min-h-[50vh]">
                    <i data-lucide="message-square" class="w-12 h-12 mb-4 opacity-50"></i>
                    <p>开始新的对话...</p>
                </div>
                
                <div v-for="(msg, index) in messages" :key="index" class="flex flex-col gap-1 max-w-4xl mx-auto animate-fade-in-up w-full">
                    <div class="flex items-center gap-2 mb-1 px-1">
                        <div v-if="msg.role === 'user'" class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold shrink-0 bg-blue-100 text-blue-600 dark:bg-blue-900 dark:text-blue-300">
                            U
                        </div>
                        <img v-else src="logo_square.png" class="w-6 h-6 rounded-md shrink-0 bg-white" alt="A">
                        <span class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">{{ msg.role === 'user' ? 'User' : 'Assistant' }}</span>
                        <span v-if="msg.source === 'autonomous'" class="text-xs bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200 px-1.5 py-0.5 rounded-full">自主行动</span>
                        <span class="text-xs text-gray-400 ml-auto">{{ msg.timestamp }}</span>
                    </div>
                    
                    <div class="prose dark:prose-invert max-w-none bg-white dark:bg-gray-800 p-4 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 relative group transition-shadow hover:shadow-md break-words">
                        <div v-html="renderMarkdown(msg.content)"></div>
                        <button @click="copyToClipboard(msg.content)" class="absolute top-2 right-2 p-1 rounded opacity-0 group-hover:opacity-100 transition-opacity hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-400 hover:text-gray-600" title="复制内容">
                            <i data-lucide="copy" class="w-3 h-3"></i>
                        </button>
                    </div>
                </div>

                <div v-if="isTyping" class="flex gap-2 max-w-4xl mx-auto w-full px-1">
                    <img src="logo_square.png" class="w-6 h-6 rounded-md shrink-0 bg-white" alt="A">
                    <div class="bg-white dark:bg-gray-800 p-3 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">
                        <div class="flex space-x-1">
                            <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 0ms"></div>
                            <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 150ms"></div>
                            <div class="w-2 h-2 bg-gray-400 rounded-full animate-bounce" style="animation-delay: 300ms"></div>
                        </div>
                    </div>
                </div>
                <div id="scroll-anchor"></div>
            </div>

            <!-- Input Area -->
            <div class="p-4 bg-white dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700 shrink-0">
                <div class="max-w-4xl mx-auto relative">
                    <textarea 
                        v-model="inputMessage" 
                        @keydown.enter.exact.prevent="sendMessage"
                        placeholder="输入指令..." 
                        class="w-full bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3 pr-12 focus:outline-none focus:ring-2 focus:ring-blue-500/50 resize-none h-14 max-h-48 transition-all scrollbar-hide text-sm sm:text-base"
                        rows="1"
                    ></textarea>
                    <button 
                        @click="sendMessage" 
                        :disabled="!inputMessage.trim() || isTyping"
                        class="absolute right-2 top-1/2 -translate-y-1/2 p-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors shadow-sm"
                    >
                        <i data-lucide="send" class="w-4 h-4"></i>
                    </button>
                </div>
                <div class="text-center mt-2 text-xs text-gray-400 dark:text-gray-500 hidden sm:block">
                    按 Enter 发送 • Shift + Enter 换行
                </div>
            </div>
        </main>

        <div v-if="activeModal" class="ga-modal-overlay fixed inset-0 z-50 flex items-center justify-center p-4">
            <div class="ga-modal-backdrop absolute inset-0 bg-black/50" @click="closeModal"></div>
            <div class="ga-modal-panel relative bg-white dark:bg-gray-800 w-full max-w-5xl max-h-[85vh] rounded-lg shadow-xl border border-gray-200 dark:border-gray-700 flex flex-col overflow-hidden">
                <div class="px-4 py-3 border-b border-gray-200 dark:border-gray-700 flex items-center justify-between">
                    <div class="font-medium text-gray-800 dark:text-gray-100">
                        <template v-if="activeModal === 'model'">模型切换</template>
                        <template v-else-if="activeModal === 'sop'">SOP 技能库</template>
                        <template v-else-if="activeModal === 'todo'">ToDo 计划</template>
                        <template v-else-if="activeModal === 'schedule'">定时触发工具</template>
                    </div>
                    <button @click="closeModal" class="p-1 rounded hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-500 dark:text-gray-300">
                        <i data-lucide="x" class="w-5 h-5"></i>
                    </button>
                </div>

                <div class="ga-modal-body flex-1 overflow-auto p-4">
                    <template v-if="activeModal === 'model'">
                        <div class="space-y-3">
                            <div class="flex items-center justify-between">
                                <div class="text-sm text-gray-500 dark:text-gray-400">点击模型切换；点钥匙配置该模型的 Key（默认不展示 Key）</div>
                                <button @click="startNewModel" class="px-3 py-2 text-sm rounded-md bg-blue-600 text-white hover:bg-blue-700">新增模型</button>
                            </div>

                            <div class="space-y-2">
                                <div v-for="(model, idx) in status.llm_list" :key="idx" class="flex items-center gap-2">
                                    <button @click="switchLLM(model[0]); closeModal()" 
                                        class="flex-1 flex items-center gap-2 px-3 py-2 text-sm rounded-md transition-colors text-left"
                                        :class="model[2] ? 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300 font-medium' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700'">
                                        <i :data-lucide="model[2] ? 'check-circle' : 'circle'" class="w-4 h-4 shrink-0"></i>
                                        <span class="truncate">{{ model[1] }}</span>
                                    </button>
                                    <button v-if="model[3]" @click.stop="openKeyEditor(model[3])" class="p-2 rounded-md border border-gray-200 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-600 dark:text-gray-200">
                                        <i data-lucide="key" class="w-4 h-4"></i>
                                    </button>
                                </div>
                            </div>

                            <div v-if="keyEditorOpen" id="ga-key-editor" class="border border-gray-200 dark:border-gray-700 rounded-md p-3 space-y-2">
                                <div class="text-sm font-medium text-gray-800 dark:text-gray-100 truncate">{{ editingTitle }}</div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
                                    <div>
                                        <div class="text-xs text-gray-500 dark:text-gray-400 mb-1">协议类型</div>
                                        <select v-model="editType" :disabled="!!editingConfigId" class="w-full bg-transparent text-gray-800 dark:text-gray-100 border border-gray-300 dark:border-gray-700 rounded px-2 py-2 text-sm focus:outline-none">
                                            <option value="oai">OpenAI-compatible</option>
                                            <option value="claude">Claude</option>
                                        </select>
                                    </div>
                                    <div>
                                        <div class="text-xs text-gray-500 dark:text-gray-400 mb-1">模型名称</div>
                                        <input v-model="editModel" class="w-full bg-transparent text-gray-800 dark:text-gray-100 border border-gray-300 dark:border-gray-700 rounded px-2 py-2 text-sm focus:outline-none" placeholder="例如 gpt-4.1 / kimi-k2.5 / claude-opus-4-6" />
                                    </div>
                                    <div class="md:col-span-2">
                                        <div class="text-xs text-gray-500 dark:text-gray-400 mb-1">API Base</div>
                                        <input v-model="editApiBase" class="w-full bg-transparent text-gray-800 dark:text-gray-100 border border-gray-300 dark:border-gray-700 rounded px-2 py-2 text-sm focus:outline-none" placeholder="例如 https://api.openai.com/v1" />
                                    </div>
                                    <div class="md:col-span-2">
                                        <div class="text-xs text-gray-500 dark:text-gray-400 mb-1">API Key</div>
                                        <input v-model="editApiKey" type="password" class="w-full bg-transparent text-gray-800 dark:text-gray-100 border border-gray-300 dark:border-gray-700 rounded px-2 py-2 text-sm focus:outline-none" placeholder="不展示已保存的 Key；输入新 Key 用于更新/新增" />
