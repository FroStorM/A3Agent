    <!-- Marked.js for Markdown rendering -->
    <!-- Use a specific version known to work well with older browsers if needed, or polyfill Array.at -->
    <script>
        // Polyfill for Array.prototype.at (needed for older WebEngine/Safari versions)
        if (!Array.prototype.at) {
            Array.prototype.at = function(n) {
                // ToInteger() abstract op
                n = Math.trunc(n) || 0;
                // Allow negative indexing from the end
                if (n < 0) n += this.length;
                // OOB access is guaranteed to return undefined
                if (n < 0 || n >= this.length) return undefined;
                // Otherwise, this is just normal property access
                return this[n];
            };
        }
        
        // Polyfill for String.prototype.at
        if (!String.prototype.at) {
            String.prototype.at = function(n) {
                n = Math.trunc(n) || 0;
                if (n < 0) n += this.length;
                if (n < 0 || n >= this.length) return undefined;
                return this[n];
            };
        }

        // Polyfill for Element.matches / Element.closest (older WebEngine)
        if (window.Element && !Element.prototype.matches) {
            Element.prototype.matches = Element.prototype.msMatchesSelector || Element.prototype.webkitMatchesSelector;
        }
        if (window.Element && !Element.prototype.closest) {
            Element.prototype.closest = function(s) {
                let el = this;
                while (el && el.nodeType === 1) {
                    if (el.matches && el.matches(s)) return el;
                    el = el.parentElement || el.parentNode;
                }
                return null;
            };
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="app.js?v=11"></script>
    <script>
        (function () {
            const STORAGE_KEY = 'ga_theme';
            const btn = document.getElementById('themeToggle');
            if (!btn) return;

            const getPrefersDark = () => {
                try {
                    return !!(window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches);
                } catch (e) {
                    return false;
                }
            };

            const apply = (mode) => {
                const html = document.documentElement;
                const isDark = mode === 'dark' || (mode === 'system' && getPrefersDark());
                const body = document.body;
                if (isDark) {
                    html.classList.add('dark');
                    if (body) body.classList.add('dark');
                } else {
                    html.classList.remove('dark');
                    if (body) body.classList.remove('dark');
                }
                html.style.colorScheme = isDark ? 'dark' : 'light';
            };

            const normalize = (v) => (v === 'light' || v === 'dark' || v === 'system') ? v : 'light';

            const readMode = () => {
                try {
                    return normalize(localStorage.getItem(STORAGE_KEY) || 'light');
                } catch (e) {
                    return 'light';
                }
            };

            const writeMode = (v) => {
                try {
                    localStorage.setItem(STORAGE_KEY, v);
                } catch (e) {
                }
            };

            const nextMode = (v) => v === 'system' ? 'light' : (v === 'light' ? 'dark' : 'system');

            const labelFor = (v) => {
                if (v === 'light') return '主题：浅色（点击切换）';
                if (v === 'dark') return '主题：深色（点击切换）';
                return '主题：跟随系统（点击切换）';
            };

            const iconFor = (v) => {
                if (v === 'light') return 'sun';
                if (v === 'dark') return 'moon';
                return 'monitor';
            };

            const render = (v) => {
                btn.title = labelFor(v);
                btn.innerHTML = '<i data-lucide="' + iconFor(v) + '" class="w-4 h-4"></i>';
                if (window.lucide) lucide.createIcons();
            };

            const setMode = (v) => {
                const mode = normalize(v);
                writeMode(mode);
                apply(mode);
                render(mode);
            };

            setMode(readMode());
            btn.addEventListener('click', () => {
                setMode(nextMode(readMode()));
            });
        })();
    </script>
